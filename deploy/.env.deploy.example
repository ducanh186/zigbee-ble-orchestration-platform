# === EC2 Deploy Configuration ===
EC2_HOST=1.2.3.4                    # Elastic IP
EC2_USER=ubuntu                     # EC2 user (ubuntu for Ubuntu AMI)
EC2_KEY=~/.ssh/your-key.pem         # SSH private key path
REMOTE_DIR=/home/ubuntu/iot-platform # Remote project directory

# === MQTT credentials (will be written to mosquitto passwd file) ===
MQTT_GATEWAY_PASS=gateway123
MQTT_CLIENT_PASS=client123
MQTT_MONITOR_PASS=monitor123

# === PostgreSQL credentials (used by docker-compose and cloud .env) ===
POSTGRES_USER=sb_user
POSTGRES_PASSWORD=sb_pass
POSTGRES_DB=sb_cloud

# === Cloud API .env overrides on EC2 ===
SB_DATABASE_URL=postgresql+asyncpg://sb_user:sb_pass@postgres:5432/sb_cloud
SB_MQTT_HOST=mosquitto
SB_MQTT_PORT=1883
SB_MQTT_USERNAME=client
SB_MQTT_PASSWORD=client123
SB_TENANT_ID=hust
SB_SITE_ID=lab01
SB_GATEWAY_ID=gw-ubuntu-01
SB_API_HOST=0.0.0.0
SB_API_PORT=8000
